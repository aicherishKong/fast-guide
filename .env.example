# ============================
# fast-guide 环境变量模板
# 复制为 .env 并填入真实值（.env 已 gitignore）
# ============================

# ---- LLM（DashScope / OpenAI 兼容）----
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_API_KEY=sk-your-api-key-here
LLM_MODEL_FAST=qwen-turbo
LLM_MODEL_DEFAULT=qwen-plus
LLM_MODEL_QUALITY=qwen-max

# ---- Embedding ----
EMBEDDING_MODEL=text-embedding-v3
EMBEDDING_DIMS=1024

# ---- PostgreSQL ----
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=fast_guide
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-db-password
# 完整 DSN（由上面变量拼接，或直接填写）
# POSTGRES_DSN=postgresql+asyncpg://postgres:password@localhost:5432/fast_guide

# ---- Redis ----
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB_CACHE=1
REDIS_DB_QUEUE=2

# ---- MinIO（本地开发）/ OSS（生产替换 endpoint）----
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_RESUMES=fast-guide-resumes
MINIO_BUCKET_AUDIO=fast-guide-audio
MINIO_BUCKET_EXPORTS=fast-guide-exports
MINIO_SECURE=false

# ---- JWT Auth ----
JWT_SECRET_KEY=change-this-to-a-random-32-char-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ---- Whisper（语音转写，可复用 LLM_API_KEY）----
WHISPER_API_KEY=sk-your-api-key-here
WHISPER_MODEL=whisper-1

# ---- 应用配置 ----
APP_ENV=development          # development | production
APP_DEBUG=true
BACKEND_CORS_ORIGINS=http://localhost:5173
